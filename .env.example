# Bitrix24
B24_DOMAIN=b24-XXXXX.bitrix24.ru

# Public domain (used to build bot event handler URL)
PUBLIC_DOMAIN=YOUR_PUBLIC_URL

# Bitrix imbot (register bot in Bitrix UI, then fill in values)
B24_IMBOT_ID=65
B24_IMBOT_CODE=your_bot_code
B24_IMBOT_NAME=Your Bot Name
B24_IMBOT_CLIENT_ID=your_bot_client_id

# Inbound webhook for bot REST calls (Bitrix: Developer resources → Inbound webhook, scope "im")
B24_WEBHOOK_URL=https://b24-XXXXX.bitrix24.ru/rest/1/your_webhook_secret/

# Seconds of operator silence before the bot resumes answering (default: 300 = 5 min)
OPERATOR_TIMEOUT_S=300

# PostgreSQL
DATABASE_URL=postgresql://myryba:myryba@postgres:5432/myryba

# Redis
REDIS_URL=redis://redis:6379/0

# HTTP
HTTP_TIMEOUT_S=10
HTTP_RETRIES=3

# LLM (OpenAI-compatible API)
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# OpenAI (or any OpenAI-compatible API — Azure, local proxy, etc.)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# Optional: custom endpoint (e.g. for Azure OpenAI or local proxy)
OPENAI_BASE_URL=

# Scraper schedule (seconds)
SCRAPER_FULL_INTERVAL_S=86400
SCRAPER_PRICE_INTERVAL_S=3600

# Admin panel (available at /admin)
# Secret key for signing session cookies — CHANGE THIS in production!
ADMIN_SECRET=change-me-in-production
# HTTP Basic Auth credentials for the admin panel.
# Leave ADMIN_PASSWORD empty to disable auth (local/dev only).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
